{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto Git Pull",
      "type": "shell",
      "command": "git pull origin main",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
